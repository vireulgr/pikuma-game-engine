$ThirdpartyDir = "E:/code/Thirdparty"
$SystemEnv = @{
  Sdl2CoreHome = "$ThirdpartyDir/SDL2-2.0.14";
  Sdl2ImageHome = "$ThirdpartyDir/SDL2_image-2.5.3";
  Sdl2MixerHome = "$ThirdpartyDir/SDL2_mixer-2.5.2";
  Sdl2TtfHome = "$ThirdpartyDir/SDL2_ttf-2.0.15";
  #set(LUA_HOME "E:/code/Thirdparty/lua-5.3.5_win64_vc16_lib")
  LibsReleaseX64 = "$ThirdpartyDir/Libs/Release_x64";
  Include = "$ThirdpartyDir/Include";
  #set(MY_THIRDPARTY_LIBS_DEB_X64 "E:/code/Thirdparty/Libs/Debug_x64")
};

$output = ConvertTo-Json $SystemEnv

Write-Host $output
